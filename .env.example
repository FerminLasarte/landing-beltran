# ══════════════════════════════════════════════════════════════
#  Copiá este archivo como ".env" y completá los valores reales.
#  El archivo .env NUNCA debe subirse a git (ya está en .gitignore).
# ══════════════════════════════════════════════════════════════

# ── GEMINI ────────────────────────────────────────────────────
# Obtené tu API Key gratuita en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_clave_de_gemini_aqui

# ── CORS ──────────────────────────────────────────────────────
# Orígenes permitidos para hacer peticiones al backend.
# Separar múltiples orígenes con coma, sin espacios.
#
# Desarrollo (dejar vacío usa los puertos localhost por defecto):
# FRONTEND_URL=
#
# Producción (reemplazá con tu dominio real):
FRONTEND_URL=https://grupobriones.com.ar,https://www.grupobriones.com.ar
