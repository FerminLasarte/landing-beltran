# ══════════════════════════════════════════════════════════════
#  .gitignore — Briones Portfolio
#  Regla de oro: si tenés dudas, agregalo acá.
# ══════════════════════════════════════════════════════════════


# ── SECRETOS Y ENTORNO  ⚠ CRÍTICO ────────────────────────────
# Ningún archivo .env (con o sin sufijo) debe llegar al repo.
.env
.env.*
!.env.example          # excepción: la plantilla SÍ se sube


# ── PYTHON ───────────────────────────────────────────────────

# Entornos virtuales — cualquier nombre de carpeta típico
venv/
.venv/
env/
.env_py/
ENV/

# Bytecode y caché del intérprete
__pycache__/
*.py[cod]              # .pyc, .pyo, .pyd
*.pyo

# Distribución y empaquetado
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib64/

# Cobertura de tests
.coverage
.coverage.*
htmlcov/
coverage.xml
nosetests.xml

# pytest / tox
.pytest_cache/
.tox/
.nox/

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json

# IPython / Jupyter
.ipynb_checkpoints/
profile_default/
ipython_config.py

# pip
pip-log.txt
pip-delete-this-directory.txt


# ── NODE / FRONTEND ───────────────────────────────────────────
node_modules/
.npm/
.yarn/
.pnp.*
.next/
out/
dist/
build/


# ── SISTEMA OPERATIVO ─────────────────────────────────────────

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Windows
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Linux
*~


# ── EDITORES E IDEs ───────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
.project
.settings/
.claude/


# ── LOGS ─────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ── OTROS ────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
*.orig
